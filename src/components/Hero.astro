---
---

<section class="hero">
  <div class="hero-inner">

    <!-- Left: Copy -->
    <div class="hero-copy">
      <div class="badge">
        <span class="badge-flag">🌍</span>
        <span>100+ languages · Real-time translation</span>
      </div>

      <h1 class="headline">
        Call anyone,<br />in any language
      </h1>

      <p class="subline">
        Don't speak their language? No problem.<br />
        AI Call translates both sides of your call<br />
        in real time — just talk naturally.
      </p>

      <div class="download-row">
        <a href="https://apps.apple.com/us/app/ai-call-phone-translator-agent/id6744344005" class="dl-btn dl-ios" target="_blank" rel="noopener">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          <div class="dl-text">
            <span class="dl-sub">Download on the</span>
            <span class="dl-main">App Store</span>
          </div>
        </a>
        <a href="https://play.google.com/store/apps/details?id=com.shaling.ai.phone.ai_phone" class="dl-btn dl-android" target="_blank" rel="noopener">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.523 15.341l-.937-1.625A6.978 6.978 0 0019 9H5a6.978 6.978 0 002.414 4.716l-.937 1.625A1 1 0 007.342 17H8v4a1 1 0 001 1h1a1 1 0 001-1v-4h2v4a1 1 0 001 1h1a1 1 0 001-1v-4h.658a1 1 0 00.865-1.659zM8.5 5.5a1 1 0 110-2 1 1 0 010 2zm7 0a1 1 0 110-2 1 1 0 010 2zM6.5 4L5 2.5M17.5 4L19 2.5"/>
          </svg>
          <div class="dl-text">
            <span class="dl-sub">Get it on</span>
            <span class="dl-main">Google Play</span>
          </div>
        </a>
      </div>

      <p class="trust-note">Free to download · No sign-up required to try</p>
    </div>

    <!-- Right: Phone Mockup -->
    <div class="hero-visual">
      <div class="phone-wrap">
        <div class="phone">
          <div class="phone-notch"></div>
          <div class="phone-screen">

            <!-- Call UI -->
            <div class="call-header">
              <div class="caller-info">
                <div class="caller-avatar">
                  <span>K</span>
                </div>
                <div class="caller-meta">
                  <span class="caller-name">Kenji · 🇯🇵</span>
                  <span class="caller-sub">Live call · AI translating</span>
                </div>
              </div>
              <div class="call-timer">01:34</div>
            </div>

            <!-- Translation feed -->
            <div class="translation-feed">
              <div class="trans-item trans-them">
                <div class="lang-tag">JA</div>
                <div class="bubble">
                  "明日の会議は何時から始まりますか？"
                </div>
              </div>
              <div class="trans-arrow">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M7 2v10M3 8l4 4 4-4" stroke="var(--color-accent)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>AI translated</span>
              </div>
              <div class="trans-item trans-you">
                <div class="lang-tag lang-en">EN</div>
                <div class="bubble bubble-you">
                  "What time does tomorrow's meeting start?"
                </div>
              </div>

              <div class="divider"></div>

              <div class="trans-item trans-you">
                <div class="lang-tag lang-en">EN</div>
                <div class="bubble bubble-you">
                  "It starts at 10 AM. I'll send the link now."
                </div>
              </div>
              <div class="trans-arrow">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M7 12V2M3 6l4-4 4 4" stroke="var(--color-accent)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>AI translated</span>
              </div>
              <div class="trans-item trans-them">
                <div class="lang-tag">JA</div>
                <div class="bubble">
                  "午前10時ですね。リンクを送ってください。"
                </div>
              </div>
            </div>

            <!-- Waveform -->
            <div class="phone-bottom">
              <div class="waveform">
                <span></span><span></span><span></span><span></span><span></span>
                <span></span><span></span><span></span><span></span><span></span>
                <span></span><span></span>
              </div>
            </div>

          </div>
        </div>

        <!-- Floating chips -->
        <div class="chip chip-left">
          <span>🇩🇪 German</span>
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
            <path d="M2 6h8M6 2l4 4-4 4" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span>🇺🇸 English</span>
        </div>
        <div class="chip chip-right">
          <span>🇨🇳 Chinese</span>
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
            <path d="M2 6h8M6 2l4 4-4 4" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span>🇫🇷 French</span>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    padding: 120px 24px 80px;
  }

  .hero-inner {
    max-width: 1080px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 72px;
  }

  .hero-copy {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--color-text-secondary);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 6px 14px;
    border-radius: 100px;
    width: fit-content;
  }

  .badge-flag {
    font-size: 15px;
  }

  .headline {
    font-size: clamp(40px, 5vw, 60px);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -2px;
    color: var(--color-text-primary);
  }

  .subline {
    font-size: 18px;
    font-weight: 400;
    line-height: 1.7;
    color: var(--color-text-secondary);
  }

  .download-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .dl-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 20px;
    border-radius: var(--radius-md);
    border: 1.5px solid var(--color-text-primary);
    background: var(--color-text-primary);
    color: white;
    transition: opacity 0.15s;
    flex-shrink: 0;
  }

  .dl-btn:hover { opacity: 0.82; }

  .dl-android {
    background: transparent;
    color: var(--color-text-primary);
    border-color: var(--color-border);
  }

  .dl-android:hover {
    background: var(--color-border);
    opacity: 1;
  }

  .dl-text {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .dl-sub {
    font-size: 10px;
    opacity: 0.7;
    line-height: 1;
  }

  .dl-main {
    font-size: 15px;
    font-weight: 600;
    line-height: 1;
  }

  .trust-note {
    font-size: 13px;
    color: var(--color-text-tertiary);
  }

  .hero-visual {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .phone-wrap {
    position: relative;
    width: 260px;
  }

  .phone {
    width: 260px;
    background: var(--color-text-primary);
    border-radius: 40px;
    padding: 14px;
    box-shadow: 0 40px 80px rgba(0,0,0,0.18), 0 8px 20px rgba(0,0,0,0.1);
  }

  .phone-notch {
    width: 80px;
    height: 8px;
    background: rgba(255,255,255,0.12);
    border-radius: 4px;
    margin: 0 auto 12px;
  }

  .phone-screen {
    background: #f9f9f9;
    border-radius: 28px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .call-header {
    background: var(--color-surface);
    padding: 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--color-border-soft);
  }

  .caller-info {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .caller-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--color-accent-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 15px;
    font-weight: 600;
    color: var(--color-accent);
  }

  .caller-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .caller-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .caller-sub {
    font-size: 10px;
    color: var(--color-accent);
    font-weight: 500;
  }

  .call-timer {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-secondary);
    font-variant-numeric: tabular-nums;
  }

  .translation-feed {
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    background: #f9f9f9;
  }

  .trans-item {
    display: flex;
    align-items: flex-start;
    gap: 7px;
  }

  .lang-tag {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.3px;
    color: var(--color-text-tertiary);
    background: white;
    border: 1px solid var(--color-border);
    padding: 2px 6px;
    border-radius: 4px;
    flex-shrink: 0;
    margin-top: 4px;
  }

  .lang-en {
    color: var(--color-accent);
    border-color: var(--color-accent-mid);
    background: var(--color-accent-soft);
  }

  .bubble {
    font-size: 11.5px;
    line-height: 1.5;
    padding: 8px 10px;
    border-radius: 12px;
    border-bottom-left-radius: 3px;
    background: white;
    color: var(--color-text-primary);
    border: 1px solid var(--color-border-soft);
    flex: 1;
  }

  .bubble-you {
    background: var(--color-accent);
    color: white;
    border-color: transparent;
    border-radius: 12px;
    border-bottom-right-radius: 3px;
    border-bottom-left-radius: 12px;
  }

  .trans-you { flex-direction: row-reverse; }

  .trans-arrow {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 0 4px;
    font-size: 9px;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.2px;
  }

  .divider {
    height: 1px;
    background: var(--color-border);
    margin: 4px 0;
  }

  .phone-bottom {
    padding: 12px 14px 16px;
    background: var(--color-surface);
    border-top: 1px solid var(--color-border-soft);
  }

  .waveform {
    display: flex;
    align-items: center;
    gap: 2.5px;
    height: 24px;
    justify-content: center;
  }

  .waveform span {
    display: block;
    width: 2.5px;
    background: var(--color-accent);
    border-radius: 2px;
    opacity: 0.55;
    animation: wave 1.2s ease-in-out infinite;
  }

  .waveform span:nth-child(1)  { height: 6px;  animation-delay: 0s; }
  .waveform span:nth-child(2)  { height: 14px; animation-delay: 0.1s; }
  .waveform span:nth-child(3)  { height: 9px;  animation-delay: 0.2s; }
  .waveform span:nth-child(4)  { height: 20px; animation-delay: 0.3s; }
  .waveform span:nth-child(5)  { height: 8px;  animation-delay: 0.4s; }
  .waveform span:nth-child(6)  { height: 17px; animation-delay: 0.5s; }
  .waveform span:nth-child(7)  { height: 12px; animation-delay: 0.6s; }
  .waveform span:nth-child(8)  { height: 22px; animation-delay: 0.7s; }
  .waveform span:nth-child(9)  { height: 7px;  animation-delay: 0.8s; }
  .waveform span:nth-child(10) { height: 15px; animation-delay: 0.9s; }
  .waveform span:nth-child(11) { height: 10px; animation-delay: 1.0s; }
  .waveform span:nth-child(12) { height: 18px; animation-delay: 1.1s; }

  @keyframes wave {
    0%, 100% { transform: scaleY(1); }
    50%       { transform: scaleY(0.35); }
  }

  .chip {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 500;
    color: var(--color-text-primary);
    background: white;
    border: 1px solid var(--color-border);
    padding: 7px 12px;
    border-radius: 100px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.07);
    white-space: nowrap;
  }

  .chip-left  { left: -72px; top: 30%; }
  .chip-right { right: -88px; bottom: 28%; }

  @media (max-width: 960px) { .chip { display: none; } }

  @media (max-width: 860px) {
    .hero-inner { flex-direction: column; gap: 52px; }
    .hero-copy  { align-items: center; text-align: center; }
    .subline    { text-align: center; }
    .badge, .trust-note { align-self: center; }
    .download-row { justify-content: center; }
  }
</style>
