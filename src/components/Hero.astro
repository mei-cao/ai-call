---
---

<section class="hero">
  <div class="hero-inner">

    <!-- Left: Copy -->
    <div class="hero-copy">
      <div class="badge">
        <span class="badge-flag">🌍</span>
        <span>100+ languages · Real-time translation</span>
      </div>

      <h1 class="headline">
        Call anyone,<br />in any language
      </h1>

      <p class="subline">
        AI Call is the real-time <strong>phone call translator</strong> that works in both directions —
        you speak your language, they hear theirs. 100+ languages, no interpreter needed.
      </p>

      <div class="download-row">
        <a href="/app-redirect?store=ios" class="dl-btn dl-ios" target="_blank" rel="noopener">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          <div class="dl-text">
            <span class="dl-sub">Download on the</span>
            <span class="dl-main">App Store</span>
          </div>
        </a>
        <a href="/app-redirect?store=android" class="dl-btn dl-android" target="_blank" rel="noopener">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.523 15.341l-.937-1.625A6.978 6.978 0 0019 9H5a6.978 6.978 0 002.414 4.716l-.937 1.625A1 1 0 007.342 17H8v4a1 1 0 001 1h1a1 1 0 001-1v-4h2v4a1 1 0 001 1h1a1 1 0 001-1v-4h.658a1 1 0 00.865-1.659zM8.5 5.5a1 1 0 110-2 1 1 0 010 2zm7 0a1 1 0 110-2 1 1 0 010 2zM6.5 4L5 2.5M17.5 4L19 2.5"/>
          </svg>
          <div class="dl-text">
            <span class="dl-sub">Get it on</span>
            <span class="dl-main">Google Play</span>
          </div>
        </a>
      </div>

      <p class="trust-note">Free to download · No sign-up required to try</p>
    </div>

    <!-- Right: Phone Mockup -->
    <div class="hero-visual">
      <div class="phone-wrap">

        <!-- Side buttons -->
        <div class="btn-vol-up"></div>
        <div class="btn-vol-down"></div>
        <div class="btn-power"></div>

        <!-- iPhone frame -->
        <div class="phone">
          <div class="phone-screen">

            <!-- Status bar -->
            <div class="status-bar">
              <span class="status-time">9:41</span>
              <div class="dynamic-island">
                <div class="di-camera"></div>
                <div class="di-speaker"></div>
              </div>
              <div class="status-icons">
                <svg width="15" height="11" viewBox="0 0 15 11" fill="white" opacity="0.9">
                  <rect x="0" y="4" width="3" height="7" rx="0.8"/>
                  <rect x="4" y="2.5" width="3" height="8.5" rx="0.8"/>
                  <rect x="8" y="0.5" width="3" height="10.5" rx="0.8"/>
                  <rect x="12" y="0" width="3" height="11" rx="0.8" opacity="0.3"/>
                </svg>
                <svg width="16" height="12" viewBox="0 0 16 12" fill="white" opacity="0.9">
                  <path d="M8 2.5C10.2 2.5 12.2 3.4 13.6 4.9L15 3.5C13.2 1.6 10.7 0.5 8 0.5C5.3 0.5 2.8 1.6 1 3.5L2.4 4.9C3.8 3.4 5.8 2.5 8 2.5Z"/>
                  <path d="M8 5.5C9.4 5.5 10.7 6.1 11.6 7L13 5.6C11.7 4.3 9.9 3.5 8 3.5C6.1 3.5 4.3 4.3 3 5.6L4.4 7C5.3 6.1 6.6 5.5 8 5.5Z"/>
                  <circle cx="8" cy="10" r="1.5"/>
                </svg>
                <div class="battery-icon">
                  <div class="battery-fill"></div>
                </div>
              </div>
            </div>

            <!-- Call screen -->
            <div class="call-screen">
              <div class="call-top">
                <div class="call-label">
                  <div class="call-dot"></div>
                  <span>AI Translating · 🇯🇵 → 🇺🇸</span>
                </div>
                <div class="caller-avatar-big">K</div>
                <div class="caller-name-big">Kenji Tanaka</div>
                <div class="call-duration">01:34</div>
              </div>

              <!-- Live caption -->
              <div class="captions">
                <div class="caption-label">Live transcript</div>
                <div class="caption-them">
                  <span class="cap-flag">🇯🇵</span>
                  <div class="cap-lines">
                    <p class="cap-original">明日の会議は何時から始まりますか？</p>
                    <p class="cap-translated">What time does tomorrow's meeting start?</p>
                  </div>
                </div>
                <div class="caption-you">
                  <div class="cap-lines cap-right">
                    <p class="cap-translated cap-trans-you">It starts at 10 AM. Sending link now.</p>
                    <p class="cap-original cap-orig-you">10時に始まります。今リンクを送ります。</p>
                  </div>
                  <span class="cap-flag">🇺🇸</span>
                </div>
              </div>

              <!-- Waveform -->
              <div class="wave-row">
                <div class="waveform">
                  <span></span><span></span><span></span><span></span><span></span>
                  <span></span><span></span><span></span><span></span><span></span>
                  <span></span><span></span><span></span><span></span><span></span>
                </div>
              </div>

              <!-- Controls -->
              <div class="call-controls">
                <button class="ctrl-btn" aria-label="Mute">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                    <path d="M12 2a3 3 0 013 3v7a3 3 0 01-6 0V5a3 3 0 013-3z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    <path d="M19 10v2a7 7 0 01-14 0v-2M12 19v3M9 22h6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  </svg>
                  <span>Mute</span>
                </button>
                <button class="ctrl-btn ctrl-end" aria-label="End call">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
                  </svg>
                  <span>End</span>
                </button>
                <button class="ctrl-btn" aria-label="Speaker">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                    <path d="M11 5L6 9H2v6h4l5 4V5zM19.07 4.93a10 10 0 010 14.14M15.54 8.46a5 5 0 010 7.07" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span>Speaker</span>
                </button>
              </div>
            </div>

          </div>
        </div>

        <!-- Floating chips -->
        <div class="chip chip-left">
          <span>🇩🇪 German</span>
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
            <path d="M2 6h8M6 2l4 4-4 4" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span>🇺🇸 English</span>
        </div>
        <div class="chip chip-right">
          <span>🇨🇳 Chinese</span>
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
            <path d="M2 6h8M6 2l4 4-4 4" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span>🇫🇷 French</span>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    padding: 120px 24px 80px;
  }

  .hero-inner {
    max-width: 1080px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 72px;
  }

  .hero-copy {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--color-text-secondary);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 6px 14px;
    border-radius: 100px;
    width: fit-content;
  }

  .badge-flag {
    font-size: 15px;
  }

  .headline {
    font-size: clamp(40px, 5vw, 60px);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -2px;
    color: var(--color-text-primary);
  }

  .subline {
    font-size: 18px;
    font-weight: 400;
    line-height: 1.7;
    color: var(--color-text-secondary);
  }

  .subline strong {
    color: var(--color-text-primary);
    font-weight: 500;
  }

  .download-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .dl-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 20px;
    border-radius: var(--radius-md);
    border: 1.5px solid var(--color-text-primary);
    background: var(--color-text-primary);
    color: white;
    transition: opacity 0.15s;
    flex-shrink: 0;
  }

  .dl-btn:hover { opacity: 0.82; }

  .dl-android {
    background: transparent;
    color: var(--color-text-primary);
    border-color: var(--color-border);
  }

  .dl-android:hover {
    background: var(--color-border);
    opacity: 1;
  }

  .dl-text {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .dl-sub {
    font-size: 10px;
    opacity: 0.7;
    line-height: 1;
  }

  .dl-main {
    font-size: 15px;
    font-weight: 600;
    line-height: 1;
  }

  .trust-note {
    font-size: 13px;
    color: var(--color-text-tertiary);
  }

  /* ── Visual ── */
  .hero-visual {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .phone-wrap {
    position: relative;
    width: 270px;
  }

  /* Side buttons */
  .btn-vol-up,
  .btn-vol-down,
  .btn-power {
    position: absolute;
    background: #2a2a2a;
    border-radius: 2px;
    z-index: 2;
  }
  .btn-vol-up  { left: -3px; top: 120px; width: 3px; height: 32px; }
  .btn-vol-down{ left: -3px; top: 162px; width: 3px; height: 32px; }
  .btn-power   { right: -3px; top: 140px; width: 3px; height: 48px; }

  /* iPhone frame */
  .phone {
    width: 270px;
    background: #1a1a1a;
    border-radius: 52px;
    padding: 10px;
    box-shadow:
      0 0 0 1px #3a3a3a,
      0 40px 80px rgba(0,0,0,0.35),
      0 12px 32px rgba(0,0,0,0.2),
      inset 0 1px 0 rgba(255,255,255,0.08);
  }

  .phone-screen {
    background: #000;
    border-radius: 44px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  /* Status bar */
  .status-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px 0;
    position: relative;
    background: #111;
  }

  .status-time {
    font-size: 13px;
    font-weight: 600;
    color: white;
    letter-spacing: -0.3px;
  }

  /* Dynamic Island */
  .dynamic-island {
    position: absolute;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    width: 96px;
    height: 30px;
    background: #000;
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    border: 1.5px solid #1e1e1e;
    box-shadow: 0 0 0 1px rgba(255,255,255,0.04);
  }

  .di-camera {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #1a1a1a;
    border: 1.5px solid #2a2a2a;
  }

  .di-speaker {
    width: 28px;
    height: 6px;
    border-radius: 3px;
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
  }

  .status-icons {
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .battery-icon {
    width: 22px;
    height: 11px;
    border: 1.5px solid rgba(255,255,255,0.7);
    border-radius: 3px;
    position: relative;
    display: flex;
    align-items: center;
    padding: 1.5px;
  }

  .battery-icon::after {
    content: '';
    position: absolute;
    right: -5px;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 5px;
    background: rgba(255,255,255,0.5);
    border-radius: 0 1px 1px 0;
  }

  .battery-fill {
    background: white;
    border-radius: 1px;
    height: 100%;
    width: 70%;
  }

  /* Call screen */
  .call-screen {
    background: linear-gradient(160deg, #0d1117 0%, #111827 40%, #0a0f1a 100%);
    display: flex;
    flex-direction: column;
    padding: 16px 16px 20px;
    gap: 16px;
    min-height: 490px;
  }

  .call-top {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding-top: 8px;
  }

  .call-label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 10px;
    font-weight: 500;
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.3px;
  }

  .call-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #34d399;
    animation: pulse-dot 2s infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .caller-avatar-big {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: linear-gradient(135deg, #3b82f6, #6366f1);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 26px;
    font-weight: 600;
    color: white;
    box-shadow: 0 0 0 3px rgba(99,102,241,0.2), 0 8px 24px rgba(99,102,241,0.3);
  }

  .caller-name-big {
    font-size: 18px;
    font-weight: 600;
    color: white;
    letter-spacing: -0.4px;
  }

  .call-duration {
    font-size: 13px;
    color: rgba(255,255,255,0.45);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.5px;
  }

  /* Captions */
  .captions {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 12px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .caption-label {
    font-size: 9px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: rgba(255,255,255,0.3);
  }

  .caption-them,
  .caption-you {
    display: flex;
    gap: 8px;
    align-items: flex-start;
  }

  .caption-you { flex-direction: row-reverse; }

  .cap-flag { font-size: 16px; line-height: 1; flex-shrink: 0; margin-top: 2px; }

  .cap-lines {
    display: flex;
    flex-direction: column;
    gap: 3px;
    flex: 1;
  }

  .cap-right { align-items: flex-end; text-align: right; }

  .cap-original {
    font-size: 11px;
    color: rgba(255,255,255,0.9);
    line-height: 1.4;
  }

  .cap-translated {
    font-size: 10px;
    color: rgba(255,255,255,0.4);
    line-height: 1.4;
  }

  .cap-orig-you  { color: rgba(255,255,255,0.9); }
  .cap-trans-you { color: rgba(255,255,255,0.4); }

  /* Waveform */
  .wave-row {
    display: flex;
    justify-content: center;
  }

  .waveform {
    display: flex;
    align-items: center;
    gap: 2px;
    height: 28px;
  }

  .waveform span {
    display: block;
    width: 2.5px;
    background: linear-gradient(to top, #3b82f6, #818cf8);
    border-radius: 2px;
    animation: wave 1.2s ease-in-out infinite;
  }

  .waveform span:nth-child(1)  { height: 6px;  animation-delay: 0s; }
  .waveform span:nth-child(2)  { height: 16px; animation-delay: 0.08s; }
  .waveform span:nth-child(3)  { height: 10px; animation-delay: 0.16s; }
  .waveform span:nth-child(4)  { height: 22px; animation-delay: 0.24s; }
  .waveform span:nth-child(5)  { height: 8px;  animation-delay: 0.32s; }
  .waveform span:nth-child(6)  { height: 18px; animation-delay: 0.40s; }
  .waveform span:nth-child(7)  { height: 26px; animation-delay: 0.48s; }
  .waveform span:nth-child(8)  { height: 14px; animation-delay: 0.56s; }
  .waveform span:nth-child(9)  { height: 20px; animation-delay: 0.64s; }
  .waveform span:nth-child(10) { height: 8px;  animation-delay: 0.72s; }
  .waveform span:nth-child(11) { height: 16px; animation-delay: 0.80s; }
  .waveform span:nth-child(12) { height: 12px; animation-delay: 0.88s; }
  .waveform span:nth-child(13) { height: 22px; animation-delay: 0.96s; }
  .waveform span:nth-child(14) { height: 7px;  animation-delay: 1.04s; }
  .waveform span:nth-child(15) { height: 14px; animation-delay: 1.12s; }

  @keyframes wave {
    0%, 100% { transform: scaleY(1); }
    50%       { transform: scaleY(0.25); }
  }

  /* Controls */
  .call-controls {
    display: flex;
    justify-content: space-around;
    align-items: center;
    padding: 0 8px;
  }

  .ctrl-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    background: rgba(255,255,255,0.08);
    border: none;
    border-radius: 20px;
    width: 60px;
    height: 60px;
    justify-content: center;
    color: white;
    cursor: default;
    transition: background 0.15s;
  }

  .ctrl-btn span {
    font-size: 9px;
    color: rgba(255,255,255,0.5);
    font-family: var(--font);
  }

  .ctrl-end {
    background: #ef4444;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    box-shadow: 0 4px 20px rgba(239,68,68,0.4);
  }

  .ctrl-end span { color: rgba(255,255,255,0.8); }

  /* Chips */
  .chip {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 500;
    color: var(--color-text-primary);
    background: white;
    border: 1px solid var(--color-border);
    padding: 7px 12px;
    border-radius: 100px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.07);
    white-space: nowrap;
  }

  .chip-left  { left: -76px; top: 28%; }
  .chip-right { right: -92px; bottom: 26%; }

  @media (max-width: 980px) { .chip { display: none; } }

  @media (max-width: 860px) {
    .hero-inner { flex-direction: column; gap: 52px; }
    .hero-copy  { align-items: center; text-align: center; }
    .subline    { text-align: center; }
    .badge, .trust-note { align-self: center; }
    .download-row { justify-content: center; }
  }
</style>
