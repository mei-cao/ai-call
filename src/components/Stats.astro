---
const stats = [
  { value: '100+', label: 'Languages supported' },
  { value: '<0.5s', label: 'Translation latency' },
  { value: '50K+', label: 'Downloads' },
  { value: '5.0★', label: 'App Store rating' },
];
---

<div class="stats-bar">
  <div class="stats-inner">
    {stats.map((s, i) => (
      <>
        <div class="stat-item">
          <span class="stat-value">{s.value}</span>
          <span class="stat-label">{s.label}</span>
        </div>
        {i < stats.length - 1 && <div class="stat-divider" />}
      </>
    ))}
  </div>
</div>

<style>
  .stats-bar {
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: 28px 24px;
  }

  .stats-inner {
    max-width: 1080px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
  }

  .stat-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    text-align: center;
  }

  .stat-value {
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -1px;
    color: var(--color-text-primary);
    line-height: 1;
  }

  .stat-label {
    font-size: 13px;
    color: var(--color-text-tertiary);
    font-weight: 400;
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: var(--color-border);
    flex-shrink: 0;
  }

  @media (max-width: 520px) {
    .stats-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
    .stat-divider {
      display: none;
    }
  }
</style>
