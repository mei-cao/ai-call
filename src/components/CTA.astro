---
---

<section class="cta-section" id="download">
  <div class="cta-inner">
    <div class="cta-box">
      <div class="cta-icon">📞</div>
      <h2 class="cta-title">Make your first<br />cross-language call</h2>
      <p class="cta-sub">
        Free to download. No sign-up needed to try.<br />
        Call anyone in the world, right now.
      </p>
      <div class="cta-downloads">
        <a href="https://apps.apple.com/us/app/ai-call-phone-translator-agent/id6744344005" class="dl-btn dl-ios" target="_blank" rel="noopener">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          <div class="dl-text">
            <span class="dl-sub">Download on the</span>
            <span class="dl-main">App Store</span>
          </div>
        </a>
        <a href="https://play.google.com/store/apps/details?id=com.shaling.ai.phone.ai_phone" class="dl-btn dl-android" target="_blank" rel="noopener">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.523 15.341l-.937-1.625A6.978 6.978 0 0019 9H5a6.978 6.978 0 002.414 4.716l-.937 1.625A1 1 0 007.342 17H8v4a1 1 0 001 1h1a1 1 0 001-1v-4h2v4a1 1 0 001 1h1a1 1 0 001-1v-4h.658a1 1 0 00.865-1.659zM8.5 5.5a1 1 0 110-2 1 1 0 010 2zm7 0a1 1 0 110-2 1 1 0 010 2z"/>
          </svg>
          <div class="dl-text">
            <span class="dl-sub">Get it on</span>
            <span class="dl-main">Google Play</span>
          </div>
        </a>
      </div>
      <div class="langs-row">
        <span>🇨🇳</span><span>🇺🇸</span><span>🇯🇵</span><span>🇩🇪</span>
        <span>🇫🇷</span><span>🇪🇸</span><span>🇰🇷</span><span>🇵🇹</span>
        <span class="langs-more">+92 languages</span>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding: 80px 24px 96px;
  }

  .cta-inner {
    max-width: 1080px;
    margin: 0 auto;
  }

  .cta-box {
    background: var(--color-text-primary);
    border-radius: var(--radius-xl);
    padding: 80px 60px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 24px;
  }

  .cta-icon {
    font-size: 48px;
    line-height: 1;
  }

  .cta-title {
    font-size: clamp(28px, 4vw, 46px);
    font-weight: 700;
    letter-spacing: -1.5px;
    color: white;
    line-height: 1.15;
  }

  .cta-sub {
    font-size: 17px;
    line-height: 1.65;
    color: rgba(255,255,255,0.55);
  }

  .cta-downloads {
    display: flex;
    gap: 12px;
    margin-top: 8px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .dl-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 13px 22px;
    border-radius: var(--radius-md);
    transition: opacity 0.15s;
  }

  .dl-btn:hover { opacity: 0.82; }

  .dl-ios {
    background: white;
    color: var(--color-text-primary);
  }

  .dl-android {
    background: transparent;
    color: white;
    border: 1.5px solid rgba(255,255,255,0.25);
  }

  .dl-android:hover {
    border-color: rgba(255,255,255,0.5);
    opacity: 1;
  }

  .dl-text {
    display: flex;
    flex-direction: column;
    gap: 1px;
    text-align: left;
  }

  .dl-sub {
    font-size: 10px;
    opacity: 0.6;
    line-height: 1;
  }

  .dl-main {
    font-size: 16px;
    font-weight: 600;
    line-height: 1;
  }

  .langs-row {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 8px;
  }

  .langs-row span { font-size: 22px; }

  .langs-more {
    font-size: 13px !important;
    color: rgba(255,255,255,0.4);
    font-family: var(--font);
    margin-left: 4px;
  }

  @media (max-width: 600px) {
    .cta-box { padding: 52px 28px; }
  }
</style>
