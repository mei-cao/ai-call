<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="logo">
      <img src="/logo.png" alt="AI Call" class="logo-img" />
      <span>AI Call</span>
    </a>

    <ul class="nav-links">
      <li><a href="#how">How it works</a></li>
      <li><a href="#scenes">Use cases</a></li>
      <li><a href="#download">Download</a></li>
    </ul>

