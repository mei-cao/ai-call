---
import { locales, localeNames, localeFlags, type Locale } from '../i18n/locales';

interface Props {
  lang?: Locale;
}
const { lang = 'en' } = Astro.props;

const homeHref = lang === 'en' ? '/' : `/${lang}/`;
---

<nav class="nav">
  <div class="nav-inner">
    <a href={homeHref} class="logo">
      <img src="/logo.png" alt="AI Call" class="logo-img" />
      <span>AI Call</span>
    </a>

    <ul class="nav-links">
      <li><a href={`${homeHref}#how`}>How it works</a></li>
      <li><a href={`${homeHref}#scenes`}>Use cases</a></li>
      <li><a href="https://blog.1aicall.com">Blog</a></li>
    </ul>

    <!-- Language Switcher -->
    <div class="lang-switcher">
      <button class="lang-btn" aria-label="Change language" aria-haspopup="true" aria-expanded="false">
        <span class="lang-flag">{localeFlags[lang]}</span>
        <span class="lang-name">{localeNames[lang]}</span>
        <svg class="lang-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none">
          <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <ul class="lang-menu" role="menu">
        {locales.map((l) => (
          <li role="menuitem">
            <a
              href={l === 'en' ? '/' : `/${l}/`}
              class={`lang-option ${l === lang ? 'lang-active' : ''}`}
            >
              <span>{localeFlags[l]}</span>
              <span>{localeNames[l]}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>

    <a href="https://apps.apple.com/us/app/ai-call-phone-translator-agent/id6744344005" class="nav-cta" target="_blank" rel="noopener">Download free</a>
  </div>
</nav>

<script is:inline>
  const btn = document.querySelector('.lang-btn');
  const menu = document.querySelector('.lang-menu');
  if (btn && menu) {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = menu.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(open));
    });
    document.addEventListener('click', () => {
      menu.classList.remove('open');
      btn.setAttribute('aria-expanded', 'false');
    });
  }
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0 24px;
    background: rgba(249, 249, 249, 0.88);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }

  .nav-inner {
    max-width: 1080px;
    margin: 0 auto;
    height: 58px;
    display: flex;
    align-items: center;
    gap: 40px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: -0.3px;
    flex-shrink: 0;
  }

  .logo-img {
    width: 32px;
    height: 32px;
    border-radius: 9px;
    flex-shrink: 0;
    display: block;
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 28px;
    flex: 1;
  }

  .nav-links a {
    font-size: 14px;
    color: var(--color-text-secondary);
    transition: color 0.15s;
  }

  .nav-links a:hover {
    color: var(--color-text-primary);
  }

  .nav-cta {
    font-size: 14px;
    font-weight: 500;
    color: white;
    background: var(--color-accent);
    padding: 8px 18px;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
    transition: opacity 0.15s;
  }

  .nav-cta:hover {
    opacity: 0.85;
  }

  /* Language switcher */
  .lang-switcher {
    position: relative;
    flex-shrink: 0;
  }

  .lang-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
    font-family: var(--font);
  }

  .lang-btn:hover {
    border-color: var(--color-text-tertiary);
    color: var(--color-text-primary);
  }

  .lang-flag { font-size: 15px; line-height: 1; }
  .lang-name { font-size: 13px; }

  .lang-chevron {
    color: var(--color-text-tertiary);
    transition: transform 0.15s;
    flex-shrink: 0;
  }

  .lang-btn[aria-expanded="true"] .lang-chevron {
    transform: rotate(180deg);
  }

  .lang-menu {
    display: none;
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
    list-style: none;
    min-width: 160px;
    overflow: hidden;
    z-index: 200;
  }

  .lang-menu.open { display: block; }

  .lang-option {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    font-size: 14px;
    color: var(--color-text-secondary);
    transition: background 0.1s;
  }

  .lang-option:hover { background: var(--color-bg); color: var(--color-text-primary); }
  .lang-active { color: var(--color-accent) !important; font-weight: 500; }

  @media (max-width: 680px) {
    .nav-links { display: none; }
    .lang-name { display: none; }
  }
</style>
