---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { nonDefaultLocales, type Locale } from '../../i18n/locales';
import { useTranslations } from '../../i18n/translations';

export function getStaticPaths() {
  return nonDefaultLocales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);

const siteUrl = 'https://1aicall.com';
const pageUrl = `${siteUrl}/${lang}/phone-call-translator`;

const hreflangs = [
  { locale: 'en', url: `${siteUrl}/phone-call-translator/` },
  ...nonDefaultLocales.map((l) => ({ locale: l, url: `${siteUrl}/${l}/phone-call-translator/` })),
];

const faqItems = [
  { q: t('pct.faq.title'), a: t('pct.what.p1') },
];
---

<Layout
  title={t('meta.pct.title')}
  description={t('meta.pct.description')}
  canonicalUrl={pageUrl}
  lang={lang}
  hreflangs={hreflangs}
>
  <Nav lang={lang} />
  <main class="pct-main">

    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <div class="bc-inner">
        <ol class="bc-list">
          <li><a href={`/${lang}/`}>Home</a></li>
          <li aria-hidden="true">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M4 2l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
          </li>
          <li aria-current="page">{t('pct.title')}</li>
        </ol>
      </div>
    </nav>

    <!-- Hero -->
    <section class="pct-hero">
      <div class="pct-hero-inner">
        <div class="eyebrow-tag">{t('pct.eyebrow')}</div>
        <h1 class="pct-title">{t('pct.title')}</h1>
        <p class="pct-sub">{t('pct.sub')}</p>
        <div class="dl-row">
          <a href="https://apps.apple.com/us/app/ai-call-phone-translator-agent/id6744344005" class="dl-btn dl-ios" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            <div class="dl-text"><span class="dl-sub">Download on the</span><span class="dl-main">App Store</span></div>
          </a>
          <a href="https://play.google.com/store/apps/details?id=com.shaling.ai.phone.ai_phone" class="dl-btn dl-android" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.523 15.341l-.937-1.625A6.978 6.978 0 0019 9H5a6.978 6.978 0 002.414 4.716l-.937 1.625A1 1 0 007.342 17H8v4a1 1 0 001 1h1a1 1 0 001-1v-4h2v4a1 1 0 001 1h1a1 1 0 001-1v-4h.658a1 1 0 00.865-1.659zM8.5 5.5a1 1 0 110-2 1 1 0 010 2zm7 0a1 1 0 110-2 1 1 0 010 2z"/></svg>
            <div class="dl-text"><span class="dl-sub">Get it on</span><span class="dl-main">Google Play</span></div>
          </a>
        </div>
        <p class="trust-line">{t('pct.trust')}</p>
      </div>
    </section>

    <!-- What is it -->
    <section class="pct-section">
      <div class="pct-section-inner pct-what-grid">
        <div class="what-text">
          <h2>{t('pct.what.title')}</h2>
          <p>{t('pct.what.p1')}</p>
          <p>{t('pct.what.p2')}</p>
          <p>{t('pct.what.p3')}</p>
        </div>
        <div class="what-stats">
          <div class="stat-box"><span class="stat-num">100+</span><span class="stat-label">{t('stats.languages')}</span></div>
          <div class="stat-box"><span class="stat-num">&lt;0.5s</span><span class="stat-label">Latency</span></div>
          <div class="stat-box"><span class="stat-num">50K+</span><span class="stat-label">{t('stats.downloads')}</span></div>
          <div class="stat-box"><span class="stat-num">4.9★</span><span class="stat-label">{t('stats.rating')}</span></div>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="pct-section pct-surface">
      <div class="pct-section-inner">
        <h2>{t('pct.how.title')}</h2>
        <p class="section-sub">{t('pct.how.sub')}</p>
        <div class="steps">
          <div class="step-card"><span class="step-n">1</span><h3>{t('pct.how.step1.title')}</h3><p>{t('pct.how.step1.desc')}</p></div>
          <div class="step-sep"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
          <div class="step-card"><span class="step-n">2</span><h3>{t('pct.how.step2.title')}</h3><p>{t('pct.how.step2.desc')}</p></div>
          <div class="step-sep"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
          <div class="step-card"><span class="step-n">3</span><h3>{t('pct.how.step3.title')}</h3><p>{t('pct.how.step3.desc')}</p></div>
        </div>
      </div>
    </section>

    <!-- Use cases -->
    <section class="pct-section">
      <div class="pct-section-inner">
        <h2>{t('pct.uc.title')}</h2>
        <div class="uc-grid">
          <div class="uc-card"><span class="uc-icon">✈️</span><h3>{t('pct.uc1.title')}</h3><p>{t('pct.uc1.desc')}</p></div>
          <div class="uc-card"><span class="uc-icon">💼</span><h3>{t('pct.uc2.title')}</h3><p>{t('pct.uc2.desc')}</p></div>
          <div class="uc-card"><span class="uc-icon">👨‍👩‍👧</span><h3>{t('pct.uc3.title')}</h3><p>{t('pct.uc3.desc')}</p></div>
          <div class="uc-card"><span class="uc-icon">🏥</span><h3>{t('pct.uc4.title')}</h3><p>{t('pct.uc4.desc')}</p></div>
          <div class="uc-card"><span class="uc-icon">📞</span><h3>{t('pct.uc5.title')}</h3><p>{t('pct.uc5.desc')}</p></div>
          <div class="uc-card"><span class="uc-icon">🎓</span><h3>{t('pct.uc6.title')}</h3><p>{t('pct.uc6.desc')}</p></div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="pct-cta">
      <div class="pct-cta-inner">
        <p class="cta-eyebrow">{t('pct.eyebrow')}</p>
        <h2 class="cta-title">{t('pct.cta.title')}</h2>
        <p class="cta-sub">{t('pct.cta.sub')}</p>
        <div class="dl-row dl-center">
          <a href="https://apps.apple.com/us/app/ai-call-phone-translator-agent/id6744344005" class="dl-btn dl-ios" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            <div class="dl-text"><span class="dl-sub">Download on the</span><span class="dl-main">App Store</span></div>
          </a>
          <a href="https://play.google.com/store/apps/details?id=com.shaling.ai.phone.ai_phone" class="dl-btn dl-android-inv" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.523 15.341l-.937-1.625A6.978 6.978 0 0019 9H5a6.978 6.978 0 002.414 4.716l-.937 1.625A1 1 0 007.342 17H8v4a1 1 0 001 1h1a1 1 0 001-1v-4h2v4a1 1 0 001 1h1a1 1 0 001-1v-4h.658a1 1 0 00.865-1.659zM8.5 5.5a1 1 0 110-2 1 1 0 010 2zm7 0a1 1 0 110-2 1 1 0 010 2z"/></svg>
            <div class="dl-text"><span class="dl-sub">Get it on</span><span class="dl-main">Google Play</span></div>
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer lang={lang} />
</Layout>

<style>
  .pct-main { padding-top: 58px; }
  .breadcrumb { background: var(--color-surface); border-bottom: 1px solid var(--color-border); padding: 10px 24px; }
  .bc-inner { max-width: 1080px; margin: 0 auto; }
  .bc-list { display: flex; align-items: center; gap: 6px; list-style: none; font-size: 13px; }
  .bc-list a { color: var(--color-text-secondary); }
  .bc-list a:hover { color: var(--color-text-primary); }
  .bc-list li[aria-current="page"] { color: var(--color-text-tertiary); }
  .bc-list svg { color: var(--color-text-tertiary); }

  .pct-hero { padding: 72px 24px 80px; background: var(--color-surface); border-bottom: 1px solid var(--color-border); text-align: center; }
  .pct-hero-inner { max-width: 680px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 20px; }
  .eyebrow-tag { font-size: 12px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; color: var(--color-accent); background: var(--color-accent-soft); padding: 5px 14px; border-radius: 100px; }
  .pct-title { font-size: clamp(40px, 6vw, 64px); font-weight: 700; letter-spacing: -2px; line-height: 1.05; color: var(--color-text-primary); }
  .pct-sub { font-size: 18px; line-height: 1.7; color: var(--color-text-secondary); max-width: 560px; }
  .dl-row { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; }
  .dl-btn { display: inline-flex; align-items: center; gap: 10px; padding: 12px 22px; border-radius: var(--radius-sm); transition: opacity 0.15s; }
  .dl-btn:hover { opacity: 0.85; }
  .dl-ios { background: var(--color-text-primary); color: white; border: none; }
  .dl-android { background: var(--color-surface); color: var(--color-text-primary); border: 1px solid var(--color-border); }
  .dl-android-inv { background: rgba(255,255,255,0.12); color: white; border: 1px solid rgba(255,255,255,0.2); }
  .dl-text { display: flex; flex-direction: column; }
  .dl-sub { font-size: 10px; opacity: 0.7; line-height: 1; }
  .dl-main { font-size: 14px; font-weight: 600; line-height: 1.3; }
  .trust-line { font-size: 13px; color: var(--color-text-tertiary); }
  .dl-center { justify-content: center; }

  .pct-section { padding: 80px 24px; border-bottom: 1px solid var(--color-border); background: var(--color-bg); }
  .pct-surface { background: var(--color-surface) !important; }
  .pct-section-inner { max-width: 1080px; margin: 0 auto; display: flex; flex-direction: column; gap: 36px; }
  .pct-section-inner h2 { font-size: clamp(24px, 3vw, 36px); font-weight: 700; letter-spacing: -0.8px; color: var(--color-text-primary); }
  .section-sub { font-size: 16px; color: var(--color-text-tertiary); margin-top: -20px; }

  .pct-what-grid { display: grid !important; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
  .what-text { display: flex; flex-direction: column; gap: 16px; }
  .what-text h2 { font-size: clamp(24px, 3vw, 36px); font-weight: 700; letter-spacing: -0.8px; color: var(--color-text-primary); }
  .what-text p { font-size: 16px; line-height: 1.75; color: var(--color-text-secondary); }
  .what-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .stat-box { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 24px 20px; display: flex; flex-direction: column; gap: 6px; }
  .stat-num { font-size: 32px; font-weight: 700; letter-spacing: -1px; color: var(--color-text-primary); line-height: 1; }
  .stat-label { font-size: 13px; color: var(--color-text-tertiary); }

  .steps { display: flex; align-items: flex-start; gap: 12px; }
  .step-card { flex: 1; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 24px 20px; display: flex; flex-direction: column; gap: 10px; }
  .step-n { width: 28px; height: 28px; border-radius: 50%; background: var(--color-accent-soft); color: var(--color-accent); font-size: 13px; font-weight: 700; display: flex; align-items: center; justify-content: center; }
  .step-card h3 { font-size: 15px; font-weight: 600; color: var(--color-text-primary); }
  .step-card p { font-size: 14px; line-height: 1.65; color: var(--color-text-secondary); }
  .step-sep { color: var(--color-text-tertiary); margin-top: 36px; flex-shrink: 0; }

  .uc-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .uc-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 28px 22px; display: flex; flex-direction: column; gap: 12px; }
  .uc-icon { font-size: 28px; }
  .uc-card h3 { font-size: 16px; font-weight: 600; color: var(--color-text-primary); }
  .uc-card p { font-size: 14px; line-height: 1.65; color: var(--color-text-secondary); }

  .pct-cta { background: var(--color-text-primary); padding: 80px 24px; text-align: center; }
  .pct-cta-inner { max-width: 560px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 20px; }
  .cta-eyebrow { font-size: 12px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; color: rgba(255,255,255,0.5); }
  .cta-title { font-size: clamp(28px, 4vw, 44px); font-weight: 700; letter-spacing: -1.2px; color: white; }
  .cta-sub { font-size: 16px; color: rgba(255,255,255,0.6); }

  @media (max-width: 860px) {
    .pct-what-grid { grid-template-columns: 1fr !important; }
    .uc-grid { grid-template-columns: 1fr 1fr; }
    .steps { flex-direction: column; }
    .step-sep { display: none; }
  }
  @media (max-width: 540px) {
    .uc-grid { grid-template-columns: 1fr; }
    .dl-row { flex-direction: column; align-items: center; }
  }
</style>
