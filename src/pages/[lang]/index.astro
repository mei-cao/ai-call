---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { nonDefaultLocales, localeNames, localeFlags, localePath, type Locale } from '../../i18n/locales';
import { useTranslations } from '../../i18n/translations';

export function getStaticPaths() {
  return nonDefaultLocales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);

const siteUrl = 'https://1aicall.com';
const pageUrl = `${siteUrl}/${lang}`;

const hreflangs = [
  { locale: 'en', url: siteUrl + '/' },
  ...nonDefaultLocales.map((l) => ({ locale: l, url: `${siteUrl}/${l}/` })),
];
---

<Layout
  title={t('meta.title')}
  description={t('meta.description')}
  canonicalUrl={pageUrl}
  lang={lang}
  hreflangs={hreflangs}
>
  <Nav lang={lang} />
  <main>

    <!-- Hero -->
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-copy">
          <div class="badge">
            <span class="badge-flag">🌍</span>
            <span>{t('hero.badge')}</span>
          </div>
          <h1 class="headline">{t('hero.headline')}</h1>
          <p class="subline">{t('hero.subline')}</p>
          <div class="download-row">
            <a href="/app-redirect?store=ios" class="dl-btn dl-ios" target="_blank" rel="noopener">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
              <div class="dl-text">
                <span class="dl-sub">Download on the</span>
                <span class="dl-main">{t('hero.dl.ios')}</span>
              </div>
            </a>
            <a href="/app-redirect?store=android" class="dl-btn dl-android" target="_blank" rel="noopener">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.523 15.341l-.937-1.625A6.978 6.978 0 0019 9H5a6.978 6.978 0 002.414 4.716l-.937 1.625A1 1 0 007.342 17H8v4a1 1 0 001 1h1a1 1 0 001-1v-4h2v4a1 1 0 001 1h1a1 1 0 001-1v-4h.658a1 1 0 00.865-1.659zM8.5 5.5a1 1 0 110-2 1 1 0 010 2zm7 0a1 1 0 110-2 1 1 0 010 2z"/>
              </svg>
              <div class="dl-text">
                <span class="dl-sub">Get it on</span>
                <span class="dl-main">{t('hero.dl.android')}</span>
              </div>
            </a>
          </div>
          <p class="trust-note">{t('hero.trust')}</p>
        </div>

        <!-- Phone mockup (visual only, no translated text needed) -->
        <div class="hero-visual">
          <div class="phone-wrap">
            <div class="btn-vol-up"></div>
            <div class="btn-vol-down"></div>
            <div class="btn-power"></div>
            <div class="phone">
              <div class="phone-screen">
                <div class="status-bar">
                  <span class="status-time">9:41</span>
                  <div class="dynamic-island">
                    <div class="di-camera"></div>
                    <div class="di-speaker"></div>
                  </div>
                  <div class="status-icons">
                    <svg width="15" height="11" viewBox="0 0 15 11" fill="white" opacity="0.9"><rect x="0" y="4" width="3" height="7" rx="0.8"/><rect x="4" y="2.5" width="3" height="8.5" rx="0.8"/><rect x="8" y="0.5" width="3" height="10.5" rx="0.8"/><rect x="12" y="0" width="3" height="11" rx="0.8" opacity="0.3"/></svg>
                    <div class="battery-icon"><div class="battery-fill"></div></div>
                  </div>
                </div>
                <div class="call-screen">
                  <div class="call-top">
                    <div class="call-label"><div class="call-dot"></div><span>AI Translating · 🌍</span></div>
                    <div class="caller-avatar-big">K</div>
                    <div class="caller-name-big">Kenji Tanaka</div>
                    <div class="call-duration">01:34</div>
                  </div>
                  <div class="captions">
                    <div class="caption-label">Live transcript</div>
                    <div class="caption-them">
                      <span class="cap-flag">🇯🇵</span>
                      <div class="cap-lines">
                        <p class="cap-original">明日の会議は何時ですか？</p>
                        <p class="cap-translated">What time is tomorrow's meeting?</p>
                      </div>
                    </div>
                  </div>
                  <div class="wave-row">
                    <div class="waveform">
                      <span></span><span></span><span></span><span></span><span></span>
                      <span></span><span></span><span></span><span></span><span></span>
                    </div>
                  </div>
                  <div class="call-controls">
                    <button class="ctrl-btn" aria-label="Mute">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 2a3 3 0 013 3v7a3 3 0 01-6 0V5a3 3 0 013-3z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M19 10v2a7 7 0 01-14 0v-2M12 19v3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                    </button>
                    <button class="ctrl-btn ctrl-end" aria-label="End">
                      <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
                    </button>
                    <button class="ctrl-btn" aria-label="Speaker">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M11 5L6 9H2v6h4l5 4V5zM19.07 4.93a10 10 0 010 14.14M15.54 8.46a5 5 0 010 7.07" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="how" id="how">
      <div class="how-inner">
        <div class="section-header">
          <span class="eyebrow">{t('how.eyebrow')}</span>
          <h2 class="section-title">{t('how.title')}</h2>
          <p class="section-sub">{t('how.sub')}</p>
        </div>
        <div class="steps-grid">
          <div class="step-card">
            <span class="step-emoji">📱</span>
            <span class="step-num">1</span>
            <h3 class="step-title">{t('how.step1.title')}</h3>
            <p class="step-desc">{t('how.step1.desc')}</p>
          </div>
          <div class="step-card">
            <span class="step-emoji">🎙️</span>
            <span class="step-num">2</span>
            <h3 class="step-title">{t('how.step2.title')}</h3>
            <p class="step-desc">{t('how.step2.desc')}</p>
          </div>
          <div class="step-card">
            <span class="step-emoji">🔄</span>
            <span class="step-num">3</span>
            <h3 class="step-title">{t('how.step3.title')}</h3>
            <p class="step-desc">{t('how.step3.desc')}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <div class="cta-inner">
        <p class="cta-eyebrow">{t('cta.eyebrow')}</p>
        <h2 class="cta-title">{t('cta.title')}</h2>
        <p class="cta-sub">{t('cta.sub')}</p>
        <div class="download-row dl-center">
          <a href="/app-redirect?store=ios" class="dl-btn dl-ios-inv" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            <div class="dl-text"><span class="dl-sub">Download on the</span><span class="dl-main">{t('hero.dl.ios')}</span></div>
          </a>
          <a href="/app-redirect?store=android" class="dl-btn dl-android-inv" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.523 15.341l-.937-1.625A6.978 6.978 0 0019 9H5a6.978 6.978 0 002.414 4.716l-.937 1.625A1 1 0 007.342 17H8v4a1 1 0 001 1h1a1 1 0 001-1v-4h2v4a1 1 0 001 1h1a1 1 0 001-1v-4h.658a1 1 0 00.865-1.659zM8.5 5.5a1 1 0 110-2 1 1 0 010 2zm7 0a1 1 0 110-2 1 1 0 010 2z"/></svg>
            <div class="dl-text"><span class="dl-sub">Get it on</span><span class="dl-main">{t('hero.dl.android')}</span></div>
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer lang={lang} />
</Layout>

<style>
  /* ── Hero ── */
  .hero { padding: 120px 24px 80px; }
  .hero-inner { max-width: 1080px; margin: 0 auto; display: flex; align-items: center; gap: 72px; }
  .hero-copy { flex: 1; display: flex; flex-direction: column; gap: 28px; }
  .badge { display: inline-flex; align-items: center; gap: 8px; font-size: 13px; color: var(--color-text-secondary); background: var(--color-surface); border: 1px solid var(--color-border); padding: 6px 14px; border-radius: 100px; width: fit-content; }
  .badge-flag { font-size: 15px; }
  .headline { font-size: clamp(40px, 5vw, 60px); font-weight: 700; line-height: 1.1; letter-spacing: -2px; color: var(--color-text-primary); white-space: pre-line; }
  .subline { font-size: 18px; line-height: 1.7; color: var(--color-text-secondary); }
  .subline strong { color: var(--color-text-primary); font-weight: 500; }
  .download-row { display: flex; gap: 12px; flex-wrap: wrap; }
  .dl-btn { display: flex; align-items: center; gap: 10px; padding: 12px 20px; border-radius: var(--radius-md); border: 1.5px solid var(--color-text-primary); background: var(--color-text-primary); color: white; transition: opacity 0.15s; flex-shrink: 0; }
  .dl-btn:hover { opacity: 0.82; }
  .dl-android { background: transparent; color: var(--color-text-primary); border-color: var(--color-border); }
  .dl-android:hover { background: var(--color-border); opacity: 1; }
  .dl-ios-inv, .dl-android-inv { background: rgba(255,255,255,0.12); color: white; border-color: rgba(255,255,255,0.2); }
  .dl-text { display: flex; flex-direction: column; gap: 1px; }
  .dl-sub { font-size: 10px; opacity: 0.7; line-height: 1; }
  .dl-main { font-size: 15px; font-weight: 600; line-height: 1; }
  .trust-note { font-size: 13px; color: var(--color-text-tertiary); }

  /* Phone mockup (abbreviated) */
  .hero-visual { flex: 1; display: flex; justify-content: center; align-items: center; }
  .phone-wrap { position: relative; width: 270px; }
  .btn-vol-up,.btn-vol-down,.btn-power { position: absolute; background: #2a2a2a; border-radius: 2px; z-index: 2; }
  .btn-vol-up  { left: -3px; top: 120px; width: 3px; height: 32px; }
  .btn-vol-down{ left: -3px; top: 162px; width: 3px; height: 32px; }
  .btn-power   { right: -3px; top: 140px; width: 3px; height: 48px; }
  .phone { width: 270px; background: #1a1a1a; border-radius: 52px; padding: 10px; box-shadow: 0 0 0 1px #3a3a3a, 0 40px 80px rgba(0,0,0,0.35); }
  .phone-screen { background: #000; border-radius: 44px; overflow: hidden; display: flex; flex-direction: column; }
  .status-bar { display: flex; align-items: center; justify-content: space-between; padding: 14px 20px 0; background: #111; position: relative; }
  .status-time { font-size: 13px; font-weight: 600; color: white; }
  .dynamic-island { position: absolute; top: 10px; left: 50%; transform: translateX(-50%); width: 96px; height: 30px; background: #000; border-radius: 20px; display: flex; align-items: center; justify-content: center; gap: 10px; }
  .di-camera { width: 10px; height: 10px; border-radius: 50%; background: #1a1a1a; }
  .di-speaker { width: 28px; height: 6px; border-radius: 3px; background: #1a1a1a; }
  .status-icons { display: flex; align-items: center; gap: 5px; }
  .battery-icon { width: 22px; height: 11px; border: 1.5px solid rgba(255,255,255,0.7); border-radius: 3px; display: flex; align-items: center; padding: 1.5px; }
  .battery-fill { background: white; border-radius: 1px; height: 100%; width: 70%; }
  .call-screen { background: linear-gradient(160deg, #0d1117 0%, #111827 40%, #0a0f1a 100%); display: flex; flex-direction: column; padding: 16px 16px 20px; gap: 16px; min-height: 480px; }
  .call-top { display: flex; flex-direction: column; align-items: center; gap: 8px; padding-top: 8px; }
  .call-label { display: flex; align-items: center; gap: 6px; font-size: 10px; color: rgba(255,255,255,0.5); }
  .call-dot { width: 6px; height: 6px; border-radius: 50%; background: #34d399; animation: pulse-dot 2s infinite; }
  @keyframes pulse-dot { 0%,100%{opacity:1} 50%{opacity:.4} }
  .caller-avatar-big { width: 64px; height: 64px; border-radius: 50%; background: linear-gradient(135deg, #3b82f6, #6366f1); display: flex; align-items: center; justify-content: center; font-size: 26px; font-weight: 600; color: white; }
  .caller-name-big { font-size: 18px; font-weight: 600; color: white; }
  .call-duration { font-size: 13px; color: rgba(255,255,255,0.45); }
  .captions { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 12px; display: flex; flex-direction: column; gap: 10px; }
  .caption-label { font-size: 9px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; color: rgba(255,255,255,0.3); }
  .caption-them { display: flex; gap: 8px; }
  .cap-flag { font-size: 16px; flex-shrink: 0; }
  .cap-lines { display: flex; flex-direction: column; gap: 3px; }
  .cap-original { font-size: 11px; color: rgba(255,255,255,0.9); line-height: 1.4; }
  .cap-translated { font-size: 10px; color: rgba(255,255,255,0.4); line-height: 1.4; }
  .wave-row { display: flex; justify-content: center; }
  .waveform { display: flex; align-items: center; gap: 2px; height: 28px; }
  .waveform span { display: block; width: 2.5px; background: linear-gradient(to top, #3b82f6, #818cf8); border-radius: 2px; animation: wave 1.2s ease-in-out infinite; }
  .waveform span:nth-child(1){height:6px} .waveform span:nth-child(2){height:16px;animation-delay:.08s} .waveform span:nth-child(3){height:10px;animation-delay:.16s} .waveform span:nth-child(4){height:22px;animation-delay:.24s} .waveform span:nth-child(5){height:8px;animation-delay:.32s} .waveform span:nth-child(6){height:18px;animation-delay:.4s} .waveform span:nth-child(7){height:26px;animation-delay:.48s} .waveform span:nth-child(8){height:14px;animation-delay:.56s} .waveform span:nth-child(9){height:20px;animation-delay:.64s} .waveform span:nth-child(10){height:8px;animation-delay:.72s}
  @keyframes wave { 0%,100%{transform:scaleY(1)} 50%{transform:scaleY(.25)} }
  .call-controls { display: flex; justify-content: space-around; align-items: center; padding: 0 8px; }
  .ctrl-btn { display: flex; flex-direction: column; align-items: center; justify-content: center; background: rgba(255,255,255,0.08); border: none; border-radius: 20px; width: 60px; height: 60px; color: white; cursor: default; }
  .ctrl-end { background: #ef4444; border-radius: 50%; width: 64px; height: 64px; }

  /* How it works */
  .how { padding: 96px 24px; background: var(--color-surface); border-top: 1px solid var(--color-border); }
  .how-inner { max-width: 1080px; margin: 0 auto; display: flex; flex-direction: column; gap: 52px; }
  .section-header { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 14px; }
  .eyebrow { font-size: 12px; font-weight: 600; letter-spacing: 1.2px; text-transform: uppercase; color: var(--color-accent); }
  .section-title { font-size: clamp(26px, 4vw, 40px); font-weight: 700; letter-spacing: -1.2px; color: var(--color-text-primary); }
  .section-sub { font-size: 16px; line-height: 1.65; color: var(--color-text-secondary); }
  .steps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .step-card { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 28px 24px; display: flex; flex-direction: column; gap: 14px; }
  .step-emoji { font-size: 28px; }
  .step-num { font-size: 12px; font-weight: 700; color: var(--color-accent); background: var(--color-accent-soft); padding: 3px 10px; border-radius: 100px; width: fit-content; }
  .step-title { font-size: 16px; font-weight: 600; letter-spacing: -0.3px; color: var(--color-text-primary); }
  .step-desc { font-size: 14px; line-height: 1.65; color: var(--color-text-secondary); }

  /* CTA */
  .cta-section { background: var(--color-text-primary); padding: 96px 24px; text-align: center; }
  .cta-inner { max-width: 560px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 20px; }
  .cta-eyebrow { font-size: 12px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; color: rgba(255,255,255,0.5); }
  .cta-title { font-size: clamp(28px, 4vw, 44px); font-weight: 700; letter-spacing: -1.2px; color: white; }
  .cta-sub { font-size: 16px; color: rgba(255,255,255,0.6); }
  .dl-center { justify-content: center; }

  @media (max-width: 860px) {
    .hero-inner { flex-direction: column; gap: 52px; }
    .hero-copy { align-items: center; text-align: center; }
    .download-row { justify-content: center; }
    .steps-grid { grid-template-columns: 1fr; }
  }
</style>
